generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==================== TENANT ====================
model Tenant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique

  // GHL Connection
  ghlLocationId   String?   @unique
  ghlAccessToken  String?   // AES-256-GCM encrypted
  ghlRefreshToken String?   // AES-256-GCM encrypted
  ghlTokenExpiry  DateTime?
  ghlConnectedAt  DateTime?
  ghlAppId        String?   // Marketplace app ID

  // Onboarding
  onboardingComplete Boolean @default(false)

  // Data mode
  dataMode        String    @default("mock") // "mock" or "live"

  // Demo tenant flag
  isDemo          Boolean   @default(false)

  // Onboarding steps (for real tenants)
  onboardingStep1 Boolean   @default(false) // Has products
  onboardingStep2 Boolean   @default(false) // Has quotes
  onboardingStep3 Boolean   @default(false) // Has reservations
  onboardingDismissed Boolean @default(false)

  // Sync progress (shown in UI during full sync)
  syncState       String?   // "syncing" | "complete" | "error" | null
  syncProgressMsg String?   // "Contactos: 2400/5000"
  lastSyncAt      DateTime?
  lastSyncError   String?

  // White-label modules
  enabledModules  Json?     @default("{\"crm\":true,\"reservations\":true,\"quotes\":true,\"catalog\":true,\"communications\":true,\"pipeline\":true}")

  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  users              User[]
  roles              Role[]
  moduleConfigs      ModuleConfig[]
  notifications      Notification[]
  products           Product[]
  quotes             Quote[]
  reservations       Reservation[]
  stationCapacity    StationCapacity[]
  grouponMappings    GrouponProductMapping[]
  tasks              Task[]
  cachedContacts     CachedContact[]
  cachedConversations CachedConversation[]
  cachedOpportunities CachedOpportunity[]
  cachedPipelines    CachedPipeline[]
  syncStatus         SyncStatus?
  seasonCalendar     SeasonCalendar[]
  destinations       Destination[]
  suppliers          Supplier[]
  serviceCategories  ServiceCategory[]
  branding           TenantBranding?
  transactions       Transaction[]
  supplierSettlements SupplierSettlement[]
  opsEvents          OpsEvent[]
  reavRegistry       REAVRegistry?
  safetyDocuments    SafetyDocument[]
  incidentReports    IncidentReport[]
  campaigns          Campaign[]
  emailTemplates     EmailTemplate[]
  promotions         Promotion[]
  storefrontConfig   StorefrontConfig?
  bookingRequests    BookingRequest[]
  documentTemplates  DocumentTemplate[]
  generatedDocuments GeneratedDocument[]
  reviews            Review[]
  reviewRequests     ReviewRequest[]
  inventoryCategories InventoryCategory[]
  inventoryItems     InventoryItem[]
  inventoryReservations InventoryReservation[]
  sizingProfiles     SizingProfile[]
  ghlAutomationConfig GHLAutomationConfig?
}

// ==================== DESTINATIONS ====================
model Destination {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  country     String   @default("ES")
  region      String?
  timezone    String   @default("Europe/Madrid")
  latitude    Float?
  longitude   Float?
  isActive    Boolean  @default(true)
  metadata    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  opsEvents   OpsEvent[]
  incidentReports IncidentReport[]
  reviews     Review[]
  inventoryItems InventoryItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ==================== SUPPLIERS ====================
model Supplier {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  cif         String?
  email       String?
  phone       String?
  website     String?
  address     String?
  contactName String?
  notes       String?
  portalEnabled Boolean @default(false)
  portalPin     String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]
  transactions Transaction[]
  settlements SupplierSettlement[]
  opsEvents   OpsEvent[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ==================== SERVICE CATEGORIES ====================
model ServiceCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  icon        String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  products    Product[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

// ==================== TENANT BRANDING ====================
model TenantBranding {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  businessName    String
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#E87B5A")
  secondaryColor  String?
  accentColor     String?
  tagline         String?
  supportEmail    String?
  supportPhone    String?
  website         String?
  address         String?
  cif             String?
  timezone        String   @default("Europe/Madrid")
  currency        String   @default("EUR")
  locale          String   @default("es-ES")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==================== USER ====================
model User {
  id            String    @id @default(cuid())
  email         String
  name          String?
  passwordHash  String?
  avatarUrl     String?
  tenantId      String
  roleId        String
  ghlUserId     String?   // Maps to GHL user ID
  isActive      Boolean   @default(true)
  emailVerified Boolean   @default(false)
  inviteToken   String?   @unique
  inviteExpires DateTime?
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role          Role      @relation(fields: [roleId], references: [id])
  notifications Notification[]

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([ghlUserId])
}

// ==================== RBAC ====================
model Role {
  id          String   @id @default(cuid())
  name        String
  tenantId    String
  isSystem    Boolean  @default(false)  // System roles can't be deleted
  permissions Json     // String array of permission keys
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([name, tenantId])
  @@index([tenantId])
}

// ==================== MODULE CONFIG ====================
model ModuleConfig {
  id          String   @id @default(cuid())
  tenantId    String
  module      String   // "comms", "pipelines", "analytics", "contacts"
  isEnabled   Boolean  @default(true)
  config      Json?    @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, module])
  @@index([tenantId])
}

// ==================== NOTIFICATIONS ====================
model Notification {
  id          String   @id @default(cuid())
  tenantId    String
  userId      String   // Target user
  type        String   // "new_message", "deal_moved", "contact_created", etc.
  title       String
  body        String?
  data        Json?    // Arbitrary payload (contactId, conversationId, etc.)
  isRead      Boolean  @default(false)
  createdAt   DateTime @default(now())

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([tenantId, createdAt])
}

// ==================== PRODUCT CATALOG ====================
model Product {
  id             String   @id @default(cuid())
  tenantId       String?  // null = global catalog (shared across all tenants)
  category       String   // "alquiler", "escuela", "clase_particular", "forfait", "locker", "apreski"
  name           String
  station        String   // "baqueira", "sierra_nevada", "valdesqui", "la_pinilla", "grandvalira", "formigal", "alto_campoo", "all"
  description    String?
  personType     String?  // "adulto", "infantil", "baby", null
  tier           String?  // "media_quality", "alta_quality", null (for equipment tiers)
  includesHelmet Boolean  @default(false)
  priceType      String   // "per_day", "per_person_per_hour", "per_session", "fixed"
  price          Float    @default(0) // Base price (1 day, media season) for display
  pricingMatrix  Json?    // Season-aware pricing: { media: {...}, alta: {...} }
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)

  // White-label relations (optional — hardcoded station/category still supported)
  destinationId     String?
  supplierId        String?
  serviceCategoryId String?

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  tenant         Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  destination    Destination?     @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  supplier       Supplier?        @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  serviceCategory ServiceCategory? @relation(fields: [serviceCategoryId], references: [id], onDelete: SetNull)
  quoteItems     QuoteItem[]

  @@index([station, category])
  @@index([category])
  @@index([destinationId])
  @@index([supplierId])
  @@index([serviceCategoryId])
}

// ==================== SEASON CALENDAR ====================
model SeasonCalendar {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  station   String   // "baqueira", "sierra_nevada", etc. or "all"
  season    String   // "media" or "alta"
  startDate DateTime
  endDate   DateTime
  label     String?  // "Navidades", "Semana Santa", etc.
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId, station])
  @@unique([tenantId, station, startDate])
}

// ==================== QUOTES (PRESUPUESTOS) ====================
model Quote {
  id              String    @id @default(cuid())
  tenantId        String
  ghlContactId    String?   // GHL contact ID
  clientName      String
  clientEmail     String?
  clientPhone     String?
  clientNotes     String?

  // Request data (from form)
  destination     String    // baqueira, sierra_nevada, formigal, alto_campoo, grandvalira
  checkIn         DateTime
  checkOut        DateTime
  adults          Int       @default(2)
  children        Int       @default(0)
  wantsAccommodation Boolean @default(false)
  wantsForfait    Boolean   @default(false)
  wantsClases     Boolean   @default(false)
  wantsEquipment  Boolean   @default(false)

  // Quote state
  status          String    @default("nuevo") // nuevo, borrador, enviado, pagado, expirado, cancelado
  totalAmount     Float     @default(0)
  expiresAt       DateTime?
  sentAt          DateTime?

  // Payment (Redsys)
  redsysOrderId    String?   @unique  // Ds_Order (12 chars, unique per payment)
  redsysPaymentUrl String?             // Generated Redsys payment URL
  paymentMethod    String?             // "redsys" | "transfer" | "cash"
  paymentStatus    String?   @default("pending") // "pending" | "paid" | "failed"
  paidAt           DateTime?
  paymentRef       String?             // Redsys auth code or transfer ref

  // PDF
  pdfUrl           String?             // URL/path to generated PDF

  // Email tracking
  emailSentAt      DateTime?           // When quote email was sent
  emailSentTo      String?             // Email address sent to
  reminderSentAt   DateTime?           // When last reminder was sent
  reminderCount    Int       @default(0)
  lastReminderStep String?             // "reminder_1" | "reminder_2" | "discount" | "expiry_warning" | "expired"

  // Post-payment follow-up tracking
  crossSellSentAt  DateTime?           // When cross-sell email was sent
  reviewSentAt     DateTime?           // When review request was sent
  preTripStep      String?             // "pre_48h" | "pre_24h" | "day_of"

  // GHL link
  ghlOpportunityId String?             // Link to GHL opportunity
  ghlPipelineId    String?             // Pipeline the opp is in
  ghlStageId       String?             // Current stage ID

  // Internal
  source           String?             // "manual" | "survey" (auto-created from GHL webhook)
  internalNotes    String?
  createdBy        String?             // User ID who created

  // Cancellation
  cancelledAt      DateTime?
  cancelReason     String?             // "cliente_solicita" | "sin_disponibilidad" | "error_presupuesto" | "otro"
  cancelType       String?             // "bono" | "devolucion" | "sin_devolucion" | "groupon"
  cancelNotes      String?             // Free text for "otro"
  refundIban       String?
  refundTitular    String?
  refundStatus     String?             // "pendiente" | "completado"
  bonoCode         String?             // Generated voucher code
  bonoAmount       Float?
  bonoExpiresAt    DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items           QuoteItem[]
  reservations    Reservation[]
  tasks           Task[]

  @@index([tenantId, status])
  @@index([tenantId, createdAt])
}

model QuoteItem {
  id          String   @id @default(cuid())
  quoteId     String
  productId   String?
  name        String   // Snapshot of product name
  description String?
  category    String?  // Product category snapshot: forfait, alquiler, clase_particular, etc.
  quantity    Int      @default(1)
  unitPrice   Float
  discount    Float    @default(0) // percentage 0-100
  totalPrice  Float

  // Per-product dates and persons
  startDate       DateTime?
  endDate         DateTime?
  numDays         Int?
  numPersons      Int?
  ageDetails      Json?     // [{age: 8, type: "niño"}, {age: 35, type: "adulto"}]

  // Ski product variables
  station         String?
  modalidad       String?   // "alpino" | "snow"
  nivel           String?   // "A" | "A+" | "B" | "B+" | "C" | "D"
  sector          String?   // "Baqueira" | "Beret" | "Formigal" etc.
  idioma          String?   // "español" | "inglés" | "francés"
  horario         String?   // "10:00" | "13:00"
  puntoEncuentro  String?   // Meeting point

  // Equipment/rental
  tipoCliente     String?   // "niño" | "adulto" | "baby" | "senior"
  gama            String?   // "media" | "alta"
  casco           Boolean?  // Helmet included
  tipoActividad   String?   // "esquí" | "snow"
  tallaBotas      String?   // Boot size (filled post-purchase)
  alturaPeso      String?   // Height/weight (filled post-purchase)
  dni             String?   // DNI (for accommodation/rental)

  // Accommodation
  regimen           String?   // "solo_alojamiento" | "desayuno" | "media_pension" | "pension_completa"
  alojamientoNombre String?   // Accommodation name

  // Insurance & extras
  seguroIncluido  Boolean?  // Insurance included (forfait)
  notes           String?

  createdAt   DateTime @default(now())

  quote       Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product     Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  tasks       Task[]

  @@index([quoteId])
}

// ==================== TASKS (auto-generated on payment) ====================
model Task {
  id            String    @id @default(cuid())
  tenantId      String
  quoteId       String
  quoteItemId   String?
  type          String    // "request_dni" | "request_sizes" | "validate_level" | "offer_insurance" | "send_location" | "check_dni" | "prepare_material"
  title         String
  description   String?
  status        String    @default("pending") // "pending" | "completed"
  dueDate       DateTime?
  assignedTo    String?   // User ID
  completedAt   DateTime?
  completedBy   String?   // User ID who completed
  createdAt     DateTime  @default(now())

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote         Quote     @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  quoteItem     QuoteItem? @relation(fields: [quoteItemId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([quoteId])
  @@index([tenantId, dueDate])
}

// ==================== RESERVATIONS ====================
model Reservation {
  id              String    @id @default(cuid())
  tenantId        String
  ghlContactId    String?
  quoteId         String?

  // Client
  clientName      String
  clientPhone     String
  clientEmail     String
  couponCode      String?

  // Booking
  source          String    // "groupon" | "caja" | "web" | "presupuesto"
  station         String
  activityDate    DateTime
  schedule        String
  language        String    @default("es")

  // Participants (for group bookings)
  participants    Json?     // array of {name, type, service, level, material}

  // Services (for individual bookings)
  services        Json?     // array of {type, quantity, modality?, level?, days?}

  // Pricing
  totalPrice      Float     @default(0)
  discount        Float     @default(0)
  paymentMethod   String?
  paymentRef      String?

  // Status
  status          String    @default("pendiente") // pendiente, confirmada, sin_disponibilidad, cancelada

  // Notes
  notes           String?
  internalNotes   String?

  // Notification tracking
  emailSentAt     DateTime?
  whatsappSentAt  DateTime?
  notificationType String?  // "confirmacion" | "sin_disponibilidad"

  // Voucher tracking (Groupon)
  voucherImageUrl     String?
  voucherSecurityCode String?
  voucherCouponCode   String?
  voucherProduct      String?
  voucherPricePaid    Float?
  voucherExpiry       DateTime?
  voucherRedeemedAt   DateTime?
  voucherRedeemed     Boolean   @default(false)

  // Calendar
  calendarFileUrl String?
  qrCodeUrl       String?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  createdBy       String?

  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  quote           Quote?    @relation(fields: [quoteId], references: [id], onDelete: SetNull)

  @@index([tenantId, status])
  @@index([tenantId, activityDate])
  @@index([tenantId, createdAt])
}

// ==================== STATION CAPACITY ====================
model StationCapacity {
  id          String   @id @default(cuid())
  tenantId    String
  station     String
  date        DateTime
  serviceType String   // "cursillo_adulto" | "cursillo_infantil" | "clase_particular"
  maxCapacity Int
  booked      Int      @default(0)

  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, station, date, serviceType])
  @@index([tenantId, station])
}

// ==================== GROUPON PRODUCT MAPPING ====================
model GrouponProductMapping {
  id              String   @id @default(cuid())
  tenantId        String
  grouponDesc     String   // Groupon product description pattern
  pattern         String   // Regex pattern to match
  services        Json     // Array of {type, days, quantity, noHelmet?}
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ==================== WEBHOOK LOG ====================
model WebhookLog {
  id          String    @id @default(cuid())
  tenantId    String?
  event       String    // GHL event type
  payload     Json      // Raw webhook payload
  status      String    @default("received") // received, processed, failed
  error       String?
  processedAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([tenantId, event])
  @@index([createdAt])
}

// ==================== GHL CACHE TABLES ====================

model CachedContact {
  id           String    @id // GHL contact ID
  tenantId     String
  tenant       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  firstName    String?
  lastName     String?
  name         String?
  email        String?
  phone        String?
  tags         Json?     // string array
  customFields Json?     // key-value pairs
  source       String?
  dateAdded    DateTime?
  lastActivity DateTime?
  dnd          Boolean   @default(false)
  raw          Json?     // full GHL response
  cachedAt     DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, name])
  @@index([tenantId, email])
  @@index([tenantId, phone])
}

model CachedConversation {
  id              String    @id // GHL conversation ID
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  contactId       String
  contactName     String?
  contactPhone    String?
  contactEmail    String?
  lastMessageBody String?
  lastMessageDate DateTime?
  lastMessageType String?   // SMS, Email, WhatsApp
  unreadCount     Int       @default(0)
  raw             Json?
  cachedAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, lastMessageDate])
}

model CachedOpportunity {
  id              String    @id // GHL opportunity ID
  tenantId        String
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  pipelineId      String
  pipelineStageId String
  name            String?
  contactId       String?
  contactName     String?
  monetaryValue   Float?
  status          String?   // open, won, lost, abandoned
  assignedTo      String?
  lastActivity    DateTime?
  raw             Json?
  cachedAt        DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([tenantId, pipelineId])
  @@index([tenantId, pipelineStageId])
}

model CachedPipeline {
  id        String   @id // GHL pipeline ID
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  stages    Json     // array of { id, name, position }
  raw       Json?
  cachedAt  DateTime @default(now())

  @@index([tenantId])
}

// ==================== SYNC QUEUE ====================

model SyncQueue {
  id          String   @id @default(cuid())
  tenantId    String
  action      String   // "updateContact", "createOpportunity", etc.
  resourceId  String   // GHL resource ID
  payload     Json     // data to send
  attempts    Int      @default(0)
  maxAttempts Int      @default(5)
  lastError   String?
  status      String   @default("pending") // pending, processing, completed, failed
  createdAt   DateTime @default(now())
  nextRetryAt DateTime @default(now())

  @@index([tenantId, status])
  @@index([status, nextRetryAt])
}

// ==================== SYNC STATUS ====================

model SyncStatus {
  id              String    @id @default(cuid())
  tenantId        String    @unique
  tenant          Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  lastFullSync    DateTime?
  lastIncrSync    DateTime?
  contactCount    Int       @default(0)
  conversationCount Int     @default(0)
  opportunityCount  Int     @default(0)
  pipelineCount   Int       @default(0)
  syncInProgress  Boolean   @default(false)
  lastError       String?
  updatedAt       DateTime  @updatedAt

  @@index([tenantId])
}

// ==================== CONTACT FORM SUBMISSIONS ====================

// ==================== ACCOUNTING ====================
model Transaction {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type          String   // "income", "expense", "supplier_settlement", "refund"
  category      String   // "reservation", "quote", "groupon", "supplier", "operational", "tax", "other"
  description   String
  amountCents   Int
  currency      String   @default("EUR")
  date          DateTime @default(now())
  referenceType String?  // "reservation", "quote", "supplier"
  referenceId   String?
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  paymentMethod String?  // "card", "transfer", "cash", "groupon"
  status        String   @default("confirmed") // "pending", "confirmed", "cancelled"
  notes         String?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, date])
  @@index([tenantId, type])
  @@index([tenantId, supplierId])
}

model SupplierSettlement {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplierId      String
  supplier        Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  periodStart     DateTime
  periodEnd       DateTime
  totalCents      Int
  commissionPct   Float    @default(0)
  commissionCents Int      @default(0)
  netCents        Int
  status          String   @default("draft") // "draft", "sent", "confirmed", "paid"
  paidAt          DateTime?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, supplierId])
}

model ContactSubmission {
  id        String   @id @default(cuid())
  nombre    String
  email     String
  telefono  String?
  asunto    String   @default("Información general")
  mensaje   String
  createdAt DateTime @default(now())

  @@index([email, createdAt])
}

// ==================== OPS CALENDAR ====================
model OpsEvent {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  title         String
  type          String   // "pickup", "dropoff", "transfer", "lesson", "activity", "staff", "maintenance", "other"
  date          DateTime
  startTime     String?  // "09:00"
  endTime       String?  // "11:00"
  allDay        Boolean  @default(false)
  destinationId String?
  destination   Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  supplierId    String?
  supplier      Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  assignedTo    String?
  status        String   @default("scheduled") // "scheduled" | "in_progress" | "completed" | "cancelled"
  notes         String?
  color         String?
  reservationId String?
  metadata      Json?
  createdBy     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId, date])
  @@index([tenantId, destinationId])
  @@index([tenantId, type])
}

// ==================== REAV COMPLIANCE ====================
model REAVRegistry {
  id              String   @id @default(cuid())
  tenantId        String   @unique
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  registryNumber  String?
  communityCode   String?
  companyName     String
  cif             String?
  registeredAt    DateTime?
  expiresAt       DateTime?
  status          String   @default("pending")
  insurancePolicy String?
  insuranceExpiry DateTime?
  civilLiability  Int?
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model SafetyDocument {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type          String
  title         String
  description   String?
  fileUrl       String?
  validFrom     DateTime?
  validUntil    DateTime?
  status        String   @default("draft")
  category      String?
  assignedTo    String?
  reviewedBy    String?
  reviewedAt    DateTime?
  metadata      Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
  @@index([tenantId, status])
}

model IncidentReport {
  id              String       @id @default(cuid())
  tenantId        String
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date            DateTime
  location        String
  destinationId   String?
  destination     Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  severity        String
  description     String
  personsInvolved String?
  actionsTaken    String?
  followUp        String?
  reportedBy      String
  status          String       @default("open")
  resolution      String?
  closedAt        DateTime?
  metadata        Json?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, date])
}

// ==================== MARKETING ====================
model Campaign {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name           String
  type           String   // "email" | "sms" | "whatsapp" | "push"
  status         String   @default("draft") // draft, scheduled, active, paused, completed, cancelled
  subject        String?
  content        String?
  templateId     String?
  audienceFilter Json?
  scheduledAt    DateTime?
  startedAt      DateTime?
  completedAt    DateTime?
  stats          Json?
  createdBy      String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sends          CampaignSend[]

  @@index([tenantId])
  @@index([tenantId, status])
}

model CampaignSend {
  id           String   @id @default(cuid())
  campaignId   String
  campaign     Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  contactEmail String
  contactName  String?
  status       String   @default("pending")
  sentAt       DateTime?
  openedAt     DateTime?
  clickedAt    DateTime?
  error        String?
  metadata     Json?
  createdAt    DateTime @default(now())

  @@index([campaignId])
  @@index([campaignId, status])
}

model EmailTemplate {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  subject   String
  body      String
  category  String?
  variables Json?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Promotion {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name          String
  code          String
  type          String   // "percentage" | "fixed" | "2x1" | "free_extra"
  value         Int?
  description   String?
  validFrom     DateTime
  validUntil    DateTime
  maxUses       Int?
  currentUses   Int      @default(0)
  minOrderCents Int?
  applicableTo  Json?
  status        String   @default("active") // active, expired, disabled
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
}

// ==================== STOREFRONT ====================
model StorefrontConfig {
  id             String   @id @default(cuid())
  tenantId       String   @unique
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  enabled        Boolean  @default(false)
  slug           String   @unique
  heroTitle      String?
  heroSubtitle   String?
  heroImageUrl   String?
  aboutText      String?
  contactEmail   String?
  contactPhone   String?
  socialLinks    Json?
  seoTitle       String?
  seoDescription String?
  customCss      String?
  showPrices     Boolean  @default(true)
  allowBookings  Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

// ==================== DOCUMENT TEMPLATES ====================
model DocumentTemplate {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  type        String   // "quote_pdf", "invoice_pdf", "booking_confirmation", "booking_reminder", "welcome_email", "settlement_pdf"
  name        String
  subject     String?
  htmlBody    String
  variables   Json?
  isDefault   Boolean  @default(false)
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, type])
}

model GeneratedDocument {
  id             String   @id @default(cuid())
  tenantId       String
  tenant         Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  templateId     String?
  type           String
  title          String
  htmlContent    String
  recipientEmail String?
  sentAt         DateTime?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, type])
}

// ==================== REVIEWS ====================
model Review {
  id               String       @id @default(cuid())
  tenantId         String
  tenant           Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerName     String
  customerEmail    String?
  rating           Int          // 1-5 stars
  title            String?
  content          String?
  destinationId    String?
  destination      Destination? @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  productId        String?
  reservationId    String?
  status           String       @default("pending") // pending, approved, rejected, featured
  response         String?
  respondedAt      DateTime?
  source           String?      // email, storefront, manual, google
  verifiedPurchase Boolean      @default(false)
  metadata         Json?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, rating])
  @@index([tenantId, destinationId])
}

model ReviewRequest {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerEmail String
  customerName  String
  reservationId String?
  token         String    @unique @default(cuid())
  sentAt        DateTime?
  completedAt   DateTime?
  status        String    @default("pending") // pending, sent, completed, expired
  createdAt     DateTime  @default(now())

  @@index([tenantId])
  @@index([token])
}

model BookingRequest {
  id            String    @id @default(cuid())
  tenantId      String
  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerName  String
  customerEmail String
  customerPhone String?
  productIds    Json
  destinationId String?
  startDate     DateTime
  endDate       DateTime?
  guests        Int       @default(1)
  notes         String?
  promoCode     String?
  status        String    @default("pending") // pending, contacted, quoted, confirmed, cancelled
  totalCents    Int?
  metadata      Json?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([tenantId, status])
}

// ==================== INVENTORY ====================
model InventoryCategory {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  sizeType    String   // "length_cm", "eu_shoe", "head_cm", "generic_sml"
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  items       InventoryItem[]

  @@unique([tenantId, slug])
  @@index([tenantId])
}

model InventoryItem {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  categoryId      String
  category        InventoryCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  destinationId   String
  destination     Destination @relation(fields: [destinationId], references: [id], onDelete: Cascade)
  name            String
  brand           String?
  model           String?
  size            String
  serialNumber    String?
  condition       String   @default("good") // "new", "good", "fair", "maintenance", "retired"
  purchaseDate    DateTime?
  purchaseCents   Int?
  seasonsPurchased Int     @default(0)
  totalRentals    Int      @default(0)
  lastMaintenance DateTime?
  notes           String?
  status          String   @default("available") // "available", "reserved", "rented", "maintenance", "retired"
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reservations    InventoryReservation[]
  maintenanceLogs MaintenanceLog[]

  @@index([tenantId, status])
  @@index([tenantId, destinationId])
  @@index([tenantId, categoryId])
  @@index([serialNumber])
}

model InventoryReservation {
  id              String   @id @default(cuid())
  tenantId        String
  tenant          Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  itemId          String
  item            InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  reservationId   String?
  customerName    String
  customerEmail   String?
  startDate       DateTime
  endDate         DateTime
  status          String   @default("reserved") // "reserved", "checked_out", "returned", "cancelled"
  checkedOutAt    DateTime?
  returnedAt      DateTime?
  damageNotes     String?
  createdAt       DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, startDate, endDate])
  @@index([itemId])
}

model MaintenanceLog {
  id          String   @id @default(cuid())
  itemId      String
  item        InventoryItem @relation(fields: [itemId], references: [id], onDelete: Cascade)
  type        String   // "tuning", "waxing", "repair", "inspection", "edge_sharpen"
  description String?
  cost        Int?     // cents
  performedBy String?
  performedAt DateTime @default(now())
  nextDueAt   DateTime?
  notes       String?

  @@index([itemId])
}

model SizingProfile {
  id            String   @id @default(cuid())
  tenantId      String
  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customerEmail String
  customerName  String
  heightCm      Int?
  weightKg      Int?
  shoeSize      String?
  age           Int?
  level         String?  // "beginner", "intermediate", "advanced", "expert"
  skiLength     String?
  bootSize      String?
  helmetSize    String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([tenantId, customerEmail])
  @@index([tenantId])
}

// ==================== GHL AUTOMATION CONFIG ====================
model GHLAutomationConfig {
  id                    String   @id @default(cuid())
  tenantId              String   @unique
  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  autoSyncFields        Boolean  @default(true)
  autoCreateOpps        Boolean  @default(true)
  autoSendTriggers      Boolean  @default(true)

  // Workflow IDs (paste from GHL)
  workflowBookingConfirmed   String?
  workflowBookingReminder    String?
  workflowPostTrip           String?
  workflowReviewRequest      String?
  workflowLoyaltyUpgrade     String?
  workflowEquipmentReady     String?
  workflowAbandonedCart      String?

  // Pipeline / stage names
  pipelineName               String?  @default("Reservas")
  stageNuevoLead             String?  @default("Nuevo Lead")
  stagePresupuestoEnviado    String?  @default("Presupuesto Enviado")
  stageReservaConfirmada     String?  @default("Reserva Confirmada")
  stagePagado                String?  @default("Pagado")
  stageCompletado            String?  @default("Completado")
  stageResenaRecibida        String?  @default("Reseña Recibida")

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}
